      <div class='message assistant d-0 d-1' data-message-id='d-2' id='msg-d-2'>
          <div class='header'>
              <span>🤖 Assistant</span>
              <div class='header-info'>
                  <div class='timestamp-row'>
                      <span class='timestamp' data-timestamp='2025-07-03T15:52:07.874907Z'>2025-07-03 15:52:07</span>
