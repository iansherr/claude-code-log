      <div class='message assistant d-0 d-3' data-message-id='d-6' id='msg-d-6'>
          <div class='header'>
              <span>🤖 Assistant</span>
              <div class='header-info'>
                  <div class='timestamp-row'>
                      <span class='timestamp' data-timestamp='2025-07-03T16:00:07.874907Z'>2025-07-03 16:00:07</span>
