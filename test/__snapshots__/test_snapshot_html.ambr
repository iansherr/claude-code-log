      <div class='message tool_result pair_last d-0 d-3' data-message-id='d-5' id='msg-d-5'>
          <div class='header'>
              <span title="ID: tool_001"></span>
              <div class='header-info'>
                  <div class='timestamp-row'>
                      <span class='timestamp' data-timestamp='2025-07-03T15:58:07.874907Z' data-duration='took 2m 0s'>2025-07-03 15:58:07</span>
                  </div>
                  
